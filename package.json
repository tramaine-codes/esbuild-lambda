{
  "author": "Tramaine L. Gillus",
  "devDependencies": {
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@eslint/js": "9.39.2",
    "@types/node": "24.10.9",
    "@types/oracledb": "6.10.2",
    "del-cli": "7.0.0",
    "eslint": "9.39.2",
    "globals": "17.4.0",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "prettier": "3.8.1",
    "serverless": "4.33.0",
    "serverless-esbuild": "1.57.0",
    "serverless-offline": "14.5.0",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.2",
    "vitest": "4.1.2"
  },
  "dependencies": {
    "dayjs": "1.11.20",
    "oracledb": "6.10.0"
